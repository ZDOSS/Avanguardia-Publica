# Copy this file to .env and fill in your values.
#
# This is the scraper (Python ETL) environment. The frontend has its own
# template at frontend/example.env (the NEXT_PUBLIC_SUPABASE_* vars).

# Supabase — required for the scraper to write data.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_service_role_key_here

# Campaign-finance enrichment (verified spoke). Free key from https://api.data.gov/signup
# (~1,000 req/hour). If unset, the scraper simply skips campaign-donor enrichment.
FEC_API_KEY=your_api_data_gov_key_here

# State-legislature roll-call votes (verified spoke). Free key from
# https://openstates.org/accounts/profile/ (~500 req/day, 10 req/min). If unset, the
# scraper simply skips state voting records.
OPENSTATES_API_KEY=your_openstates_api_key_here

# News aggregator API keys (all optional — the GDELT fallback requires no key).
CURRENTS_API_KEY=your_currents_api_key_here        # https://currentsapi.services (1,000 req/day free)
NEWSDATA_API_KEY=your_newsdata_api_key_here        # https://newsdata.io (200 req/day free, requires attribution)
THENEWSAPI_KEY=your_thenewsapi_key_here            # https://www.thenewsapi.com (100 req/day free)
NEWSAPI_KEY=your_newsapi_key_here                  # https://newsapi.org (DEV ONLY — not used in production)
